                      <Style><Border><Style>Solid</Style></Border><BackgroundColor>Gainsboro</BackgroundColor></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Hdr_OpeningBalance">
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>Opening Balance</Value><Style><FontFamily>Calibri</FontFamily><FontSize>8.5pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border><BackgroundColor>Gainsboro</BackgroundColor></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Hdr_Debit">
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>Debit</Value><Style><FontFamily>Calibri</FontFamily><FontSize>8.5pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border><BackgroundColor>Gainsboro</BackgroundColor></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Hdr_Credit">
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>Credit</Value><Style><FontFamily>Calibri</FontFamily><FontSize>8.5pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border><BackgroundColor>Gainsboro</BackgroundColor></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Hdr_ClosingBalance">
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>Closing Balance</Value><Style><FontFamily>Calibri</FontFamily><FontSize>8.5pt</FontSize><FontWeight>Bold</FontWeight></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>Solid</Style></Border><BackgroundColor>Gainsboro</BackgroundColor></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell></TablixCells></TablixRow>
                
                <TablixRow><Height>0.45cm</Height><TablixCells>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Det_LedgerHead">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!LedgerHead.Value</Value><Style><FontFamily>Calibri</FontFamily><FontSize>8pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>None</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Det_OpeningBalance">
