                      <Style><Border><Style>None</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Det_Credit">
                      <CanGrow>true</CanGrow>
                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!Credit.Value</Value><Style><FontFamily>Calibri</FontFamily><FontSize>8pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
                      <Style><Border><Style>None</Style></Border></Style>
                    </Textbox>
                  </CellContents>
                </TablixCell>                <TablixCell>
                  <CellContents>
