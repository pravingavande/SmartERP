<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="ReportSource">
      <ConnectionProperties><DataProvider>System.Data.DataSet</DataProvider><ConnectString /></ConnectionProperties>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="TrialBalance">
      <Query><DataSourceName>ReportSource</DataSourceName><CommandText /></Query>
      <Fields>
        <Field Name="OrganizationHeader"><DataField>OrganizationHeader</DataField></Field>
        <Field Name="Address"><DataField>Address</DataField></Field>
        <Field Name="ReportTitle"><DataField>ReportTitle</DataField></Field>
        <Field Name="FilterText"><DataField>FilterText</DataField></Field>
        <Field Name="PrintedOn"><DataField>PrintedOn</DataField></Field>
        <Field Name="LedgerHead"><DataField>LedgerHead</DataField></Field>
        <Field Name="OpeningBalance"><DataField>OpeningBalance</DataField></Field>
        <Field Name="Debit"><DataField>Debit</DataField></Field>
        <Field Name="Credit"><DataField>Credit</DataField></Field>
        <Field Name="ClosingBalance"><DataField>ClosingBalance</DataField></Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Tablix Name="MainTablix">
            <TablixBody>
              <TablixColumns><TablixColumn><Width>5cm</Width></TablixColumn><TablixColumn><Width>3.55cm</Width></TablixColumn><TablixColumn><Width>3.55cm</Width></TablixColumn><TablixColumn><Width>3.55cm</Width></TablixColumn><TablixColumn><Width>3.55cm</Width></TablixColumn></TablixColumns>
              <TablixRows>
                <TablixRow><Height>0.55cm</Height><TablixCells>                <TablixCell>
                  <CellContents>
                    <Textbox Name="Hdr_LedgerHead">
