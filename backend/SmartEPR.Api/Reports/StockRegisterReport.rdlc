                      <Paragraphs><Paragraph><TextRuns><TextRun><Value>=Fields!ItemGroup.Value</Value><Style><FontFamily>Calibri</FontFamily><FontSize>8pt</FontSize></Style></TextRun></TextRuns></Paragraph></Paragraphs>
